<screen permanent="true">
	<view extends="lv_obj" style_bg_color="#background_default">
		<lv_obj
			style_align="center"
			width="28%"
			height="50%"
			style_radius="100%"
			style_border_color="0xEAECEC"
			style_bg_color="0xEAECEC"
			style_border_width="3"
			style_pad_all="0"
		>
			<lv_button
				style_bg_color="#rb_red"
				style_align="center"
				width="100%"
				height="100%"
				style_radius="100%"
				style_border_color="0x490000"
				style_border_width="10"
				style_layout="flex"
				flex_flow="column"
				style_flex_main_place="center"
				style_flex_cross_place="center"
				style_pad_row="10%"
				style_pad_left="55"
			>
				<lv_label
					text="Start"
					style_bg_color="#background_default"
					style_text_color="0xFFF"
					style_text_font="large_font"
					style_text_align="center"
					style_align="center"
				/>
				<lv_label
					text="Engine"
					style_bg_color="#background_default"
					style_text_color="0xFFF"
					style_text_font="large_font"
					style_text_align="center"
					style_align="center"
				/>
				<lv_label
					text="Stop"
					style_bg_color="#background_default"
					style_text_color="0xFFF"
					style_text_font="large_font"
					style_text_align="center"
					style_align="right_mid"
				/>
			</lv_button>
		</lv_obj>
	</view>
</screen>
