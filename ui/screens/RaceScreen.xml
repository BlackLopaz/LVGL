<screen permanent="true">
	<styles>
		<style
			name="style_overall_grid"
			layout="grid"
			grid_column_dsc_array="fr(1) fr(2)"
			grid_row_dsc_array="fr(1)"
			width="100%"
			height="100%"
			pad_all="0"
			pad_column="0"
			pad_row="0"
			bg_color="0x000"
		/>

		<style
			name="style_left_grid"
			layout="grid"
			grid_column_dsc_array="fr(1) fr(1)"
			grid_row_dsc_array="fr(1) fr(2) fr(1)"
			width="100%"
			height="100%"
			pad_all="0"
			pad_column="0"
			pad_row="0"
			bg_color="0x000"
		/>
	</styles>
	<view>
		<style name="style_overall_grid" />
		<GridScreen
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		/>
	</view>
</screen>
