<screen permanent="true">
	<styles>
		<style
			name="style_overall_grid"
			layout="grid"
			grid_column_dsc_array="fr(1) fr(2)"
			grid_row_dsc_array="fr(1)"
			width="100%"
			height="100%"
			pad_all="0"
			pad_column="0"
			pad_row="0"
			bg_color="0x000"
		/>

		<style
			name="style_left_grid"
			layout="grid"
			grid_column_dsc_array="fr(1)"
			grid_row_dsc_array="fr(1) fr(4)"
			width="100%"
			height="100%"
			pad_all="0"
			pad_column="0"
			pad_row="0"
			bg_color="0x000"
		/>
	</styles>
	<view>
		<style name="style_overall_grid" />
		<GridScreen
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_border_color="#background_default"
		/>

		<lv_obj
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_bg_color="#background_default"
			style_border_color="#background_default"
		>
			<style name="style_left_grid" />
			<lv_button
				style_bg_color="#rb_red"
				style_grid_cell_column_pos="0"
				style_grid_cell_row_pos="0"
				style_grid_cell_x_align="center"
				style_grid_cell_y_align="center"
			>
				<lv_label text="Activate DJ" style_bg_color="0x000" style_text_color="0xFFF" />
			</lv_button>
			<Tile
				number_text="9899"
				text="RPM"
				style_grid_cell_column_pos="0"
				style_grid_cell_row_pos="1"
				style_grid_cell_x_align="stretch"
				style_grid_cell_y_align="stretch"
				text_font="&amp;large_font"
			/>
		</lv_obj>
	</view>
</screen>
