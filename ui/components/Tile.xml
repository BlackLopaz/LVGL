<component>
	<api>
		<prop name="number" type="int" default="40" />
		<prop name="text" type="string" default="real text" />
	</api>

	<styles>
		<style
			name="style_tile"
			bg_opa="100%"
			bg_color="0x000"
			radius="6"
			pad_all="0"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			border_width="1"
			border_color="0xCCCCCC"
			pad_row="2"
		/>

		<style name="style_number" text_font="lv_font_montserrat_20" text_color="0xfff" text_align="center" />

		<style name="style_text" text_font="lv_font_montserrat_8" text_color="0xfff" text_align="center" />
	</styles>

	<view>
		<lv_obj width="100%" height="100%">
			<style name="style_tile" />

			<lv_label text="$number" width="100%" style_text_align="center">
				<style name="style_number" />
			</lv_label>

			<lv_label text="$text" width="100%" style_text_align="center">
				<style name="style_text" />
			</lv_label>
		</lv_obj>
	</view>
</component>
