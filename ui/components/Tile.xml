<component>
	<api>
		<prop name="number" type="int" default="40" />
		<prop name="text" type="string" default="real text" />
		<prop name="tile_pos_x" type="int" default="0" />
		<prop name="tile_pos_y" type="int" default="0" />
	</api>

	<styles>
		<style
			name="style_tile"
			bg_opa="100%"
			bg_color="0x000"
			radius="6"
			pad_all="6"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			border_width="1"
			border_color="0xCCCCCC"
			pad_row="2"
		/>

		<style name="style_number" text_font="lv_font_montserrat_20" text_color="0xfff" text_align="center" />

		<style name="style_text" text_font="lv_font_montserrat_12" text_color="0xfff" text_align="center" />
	</styles>

	<view>
		<lv_obj x="$tile_pos_x" y="$tile_pos_y" width="content" height="content">
			<style name="style_tile" />

			<lv_label text="$number">
				<style name="style_number" />
			</lv_label>

			<lv_label text="$text">
				<style name="style_text" />
			</lv_label>
		</lv_obj>
	</view>
</component>
