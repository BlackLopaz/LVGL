<component>
	<api>
		<prop name="number_text" type="string" default="40.0" />
		<prop name="text" type="string" default="real text" />
		<prop name="text_color" type="color" default="0xfff" />
		<prop name="number_font" type="font" default="&amp;lv_font_montserrat_20" />
		<prop name="text_font" type="font" default="&amp;lv_font_montserrat_8" />
	</api>

	<styles>
		<style
			name="style_tile"
			bg_opa="100%"
			bg_color="#background_default"
			radius="6"
			pad_all="6"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			border_width="5"
			border_color="#rb_red"
			pad_row="2"
		/>

		<style name="style_number" text_font="$number_font" text_color="0xfff" text_align="center" />

		<style name="style_text" text_font="$text_font" text_color="0xfff" text_align="center" />
	</styles>

	<view extends="lv_obj">
		<style name="style_tile" />

		<lv_label text="$number_text" width="100%" style_text_align="center">
			<style name="style_number" />
		</lv_label>

		<lv_label text="$text" width="100%" style_text_align="center">
			<style name="style_text" />
		</lv_label>
	</view>
</component>
