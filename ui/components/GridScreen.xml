<component>
	<previews>
		<preview name="DefaultTargetDisplay" width="1024" height="600" style_bg_color="0x151515" />
	</previews>
	<styles>
		<style
			name="style_grid"
			layout="grid"
			grid_column_dsc_array="fr(1) fr(1)"
			grid_row_dsc_array="fr(1) fr(2) fr(1)"
			width="100%"
			height="100%"
			pad_all="10"
			pad_column="8"
			pad_row="8"
		/>

		<style
			name="cell_0_0"
			grid_cell_column_pos="0"
			grid_cell_row_pos="0"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_1_0"
			grid_cell_column_pos="1"
			grid_cell_row_pos="0"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_0_1"
			grid_cell_column_pos="0"
			grid_cell_row_pos="1"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_1_1"
			grid_cell_column_pos="1"
			grid_cell_row_pos="1"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>

		<style name="debug_red" bg_color="0xFF0000" />
		<style name="debug_green" bg_color="0x00FF00" />
		<style name="debug_blue" bg_color="0x0000FF" />
		<style name="debug_yellow" bg_color="0xFFFF00" />
	</styles>

	<view extends="lv_obj" width="1024" height="600">
		<style name="style_grid" selector="main" />

		<!-- Time, maybe use string instead of int for this? Good way to display time? H:MM:SS-->
		<Tile
			number="10"
			text="CURRENT"
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		/>
		<Tile
			number="1"
			text="RED BULL"
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="1"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		/>
		<!-- Button to play Max theme -->
		<ConfigurableButton
			text="Activate DRS"
			text_colour="0xFFF"
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		/>
		<lv_obj
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="1"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<lv_obj
				style_layout="grid"
				style_grid_column_dsc_array="fr(1) fr(1)"
				style_grid_row_dsc_array="fr(1)"
				width="100%"
				height="100%"
			>
				<!-- Another time field -->
				<Tile
					number="40"
					text="BEST LAP"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>

				<Tile
					number="9888"
					text="RPM"
					style_grid_cell_column_pos="1"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>
			</lv_obj>
		</lv_obj>
	</view>
</component>
