<component>
	<previews>
		<preview name="DefaultTargetDisplay" width="1024" height="600" style_bg_color="0x151515" />
	</previews>
	<styles>
		<style
			name="style_grid"
			layout="grid"
			grid_column_dsc_array="fr(1) fr(1)"
			grid_row_dsc_array="fr(1) fr(2) fr(1)"
			width="100%"
			height="100%"
			pad_all="0"
			pad_column="0"
			pad_row="0"
			bg_color="#background_default"
		/>

		<style
			name="cell_0_0"
			grid_cell_column_pos="0"
			grid_cell_row_pos="0"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_1_0"
			grid_cell_column_pos="1"
			grid_cell_row_pos="0"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_0_1"
			grid_cell_column_pos="0"
			grid_cell_row_pos="1"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>
		<style
			name="cell_1_1"
			grid_cell_column_pos="1"
			grid_cell_row_pos="1"
			grid_cell_x_align="stretch"
			grid_cell_y_align="stretch"
		/>

		<style name="debug_red" bg_color="0xFF0000" />
		<style name="debug_green" bg_color="0x00FF00" />
		<style name="debug_blue" bg_color="0x0000FF" />
		<style name="debug_yellow" bg_color="0xFFFF00" />

		<style
			name="style_tile"
			bg_opa="100%"
			bg_color="#background_default"
			radius="6"
			pad_all="6"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			border_width="5"
			border_color="#rb_red"
			pad_row="2"
		/>
	</styles>

	<view extends="lv_obj" width="1024" height="600">
		<style name="style_grid" selector="main" />

		<!-- Time, maybe use string instead of int for this? Good way to display time? H:MM:SS-->
		<Tile
			number_text="0:55:23"
			text="CURRENT"
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		/>
		<lv_obj
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="1"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<style name="style_tile" />

			<lv_label
				text="1"
				width="100%"
				style_text_font="large_font"
				style_text_color="0xfff"
				style_text_align="center"
			/>

			<lv_label
				text="RED BULL"
				width="100%"
				style_text_font="large_font"
				style_text_color="#rb_red"
				style_text_align="center"
			/>
		</lv_obj>
		<!-- Button to play Max theme -->
		<lv_obj
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_bg_color="#background_default"
			style_border_width="5"
			style_border_color="#background_default"
		>
			<lv_obj
				style_layout="grid"
				style_grid_column_dsc_array="fr(1) fr(1)"
				style_grid_row_dsc_array="fr(1)"
				width="100%"
				height="100%"
				style_bg_color="#background_default"
				style_border_color="#background_default"
			>
				<lv_button
					style_bg_color="#rb_red"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="center"
					style_grid_cell_y_align="center"
				>
					<lv_label text="Activate DRS" style_bg_color="#background_default" style_text_color="0xFFF" />
				</lv_button>
				<lv_image
					style_grid_cell_column_pos="1"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
					scale_x="70"
					scale_y="70"
					src="MonsterVRedbull_file"
				/>
			</lv_obj>
		</lv_obj>
		<lv_obj
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="1"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_bg_color="#background_default"
			style_border_color="#background_default"
		>
			<lv_obj
				style_layout="grid"
				style_grid_column_dsc_array="fr(1)"
				style_grid_row_dsc_array="fr(1) fr(1)"
				width="100%"
				height="100%"
				style_bg_color="#background_default"
				style_border_color="#background_default"
			>
				<!-- Another time field -->
				<Tile
					number_text="1:36:43"
					text="BEST LAP"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>

				<Tile
					number_text="37"
					text="TEMP"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="1"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>
			</lv_obj>
		</lv_obj>
		<lv_obj
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="2"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_bg_color="#background_default"
			style_border_color="#background_default"
		>
			<lv_obj
				style_layout="grid"
				style_grid_column_dsc_array="fr(1) fr(1)"
				style_grid_row_dsc_array="fr(1)"
				width="100%"
				height="100%"
				style_bg_color="#background_default"
				style_border_color="#background_default"
			>
				<!-- Another time field -->
				<Tile
					number_text="77"
					text="SPEED"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>

				<Tile
					number_text="48.1"
					text="FUEL"
					style_grid_cell_column_pos="1"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>
			</lv_obj>
		</lv_obj>
		<lv_obj
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="2"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
			style_bg_color="#background_default"
			style_border_color="#background_default"
		>
			<lv_obj
				style_layout="grid"
				style_grid_column_dsc_array="fr(1) fr(1)"
				style_grid_row_dsc_array="fr(1)"
				width="100%"
				height="100%"
				style_bg_color="#background_default"
				style_border_color="#background_default"
			>
				<!-- Another time field -->
				<Tile
					number_text="1"
					text="POS"
					style_grid_cell_column_pos="0"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>

				<Tile
					number_text="56"
					text="LAP"
					style_grid_cell_column_pos="1"
					style_grid_cell_row_pos="0"
					style_grid_cell_x_align="stretch"
					style_grid_cell_y_align="stretch"
				/>
			</lv_obj>
		</lv_obj>
	</view>
</component>
