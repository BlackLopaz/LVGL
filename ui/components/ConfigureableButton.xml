<component>
	<api>
		<prop name="x" type="int" default="12" />
		<prop name="y" type="int" default="24" />
		<prop name="text" type="string" default="button" />
	</api>

	<styles>
		<style
			name="style_base"
			bg_opa="100%"
			bg_color="#rb_red"
			width="content"
			height="content"
			radius="$x"
			pad_hor="$x"
			pad_ver="$y"
			text_color="0xfff"
		/>

		<style name="style_pressed" recolor="0xfff" recolor_opa="20%" />
	</styles>

	<view extends="lv_button">
		<style name="style_base" />
		<style name="style_pressed" selector="pressed" />

		<lv_label text="$text" align="center" />
	</view>
</component>
